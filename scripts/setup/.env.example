# Copy to .env and fill in. Never commit .env.  (CDP §6)
# Generate certs first:  ./generate_certs.sh

# --- Elasticsearch security (required) ---
ELASTIC_PASSWORD=change_me_strong_password
# Password for the built-in kibana_system user. After the stack is up, set it with:
#   curl -u elastic:$ELASTIC_PASSWORD -k -X POST \
#     https://localhost:9200/_security/user/kibana_system/_password \
#     -H 'Content-Type: application/json' -d '{"password":"<KIBANA_PASSWORD>"}'
KIBANA_PASSWORD=change_me_kibana_password

# --- SOAR / LLM governance (CDP §4, §12.3, §12.4) ---
# Default is a LOCAL Ollama model so telemetry stays on campus.
LLM_API_URL=http://host.docker.internal:11434/v1/chat/completions
LLM_MODEL=llama3.1
# Only set true if you accept SANITISED prompts going to a hosted model.
LLM_ALLOW_HOSTED=false
# Keep false: autonomous isolation is Deferred Scope; the agent drafts, a human approves.
AUTONOMOUS_ISOLATION=false

# --- Notifications ---
# Private ntfy topic for CRITICAL_THREAT / SOAR push alerts (Logstash + ai-agent).
# Anyone who knows the topic name can read your alerts — use a long, random,
# non-guessable value and never commit the real one.
NTFY_TOPIC=change_me_private_ntfy_topic
